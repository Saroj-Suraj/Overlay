<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="52dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/toolbar_bg"
    android:paddingTop="8dp"
    android:paddingBottom="10dp"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:elevation="16dp">

    <!-- Drag handle -->
    <View
        android:id="@+id/dragHandle"
        android:layout_width="28dp"
        android:layout_height="4dp"
        android:background="@color/border"
        android:layout_marginBottom="6dp" />

    <!-- Tools -->
    <ImageButton android:id="@+id/btnPen"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_menu_edit"
        android:contentDescription="Pen" />

    <ImageButton android:id="@+id/btnPencil"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_menu_edit"
        android:alpha="0.5"
        android:contentDescription="Pencil" />

    <ImageButton android:id="@+id/btnHighlighter"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_menu_add"
        android:contentDescription="Highlighter" />

    <ImageButton android:id="@+id/btnEraser"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:contentDescription="Eraser" />

    <!-- Divider -->
    <View style="@style/Divider" />

    <!-- Color dot -->
    <View
        android:id="@+id/btnColor"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/circle_white"
        android:layout_margin="4dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Color" />

    <!-- Size dot -->
    <View
        android:id="@+id/btnSize"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:background="@drawable/circle_gray"
        android:layout_margin="4dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Size" />

    <!-- Divider -->
    <View style="@style/Divider" />

    <!-- Undo / Redo / Clear -->
    <ImageButton android:id="@+id/btnUndo"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_menu_revert"
        android:contentDescription="Undo" />

    <ImageButton android:id="@+id/btnRedo"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_menu_send"
        android:contentDescription="Redo" />

    <ImageButton android:id="@+id/btnClear"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="@color/red"
        android:contentDescription="Clear" />

    <!-- Divider -->
    <View style="@style/Divider" />

    <!-- Draw/View mode toggle -->
    <ImageButton android:id="@+id/btnMode"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_menu_view"
        android:contentDescription="Toggle draw mode" />

    <!-- Prev / page indicator / Next -->
    <ImageButton android:id="@+id/btnPrevPage"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_media_previous"
        android:contentDescription="Previous page" />

    <TextView
        android:id="@+id/tvPageIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1/1"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:gravity="center" />

    <ImageButton android:id="@+id/btnNextPage"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_media_next"
        android:contentDescription="Next page" />

    <ImageButton android:id="@+id/btnNewPage"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_input_add"
        android:tint="@color/teal"
        android:contentDescription="New page" />

    <!-- Divider -->
    <View style="@style/Divider" />

    <!-- Save / Close -->
    <ImageButton android:id="@+id/btnSave"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_menu_save"
        android:tint="@color/amber"
        android:contentDescription="Save" />

    <ImageButton android:id="@+id/btnClose"
        style="@style/ToolBtn"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="@color/text_dim"
        android:contentDescription="Close overlay" />

</LinearLayout>
